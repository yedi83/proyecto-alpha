# Config del ENSAYO de Fase B (cuenta DEMO de la fontanería — jamas la del bot del lab)
EXCHANGE_ID=binance
EXCHANGE_TESTNET=true      # true = demo trading (enable_demo_trading)
DRY_RUN=false              # el ensayo SI envia ordenes (a la demo)
API_KEY=keys_demo_de_la_fontaneria
API_SECRET=secret_demo_de_la_fontaneria
EQUITY_CAP=750             # sizing como si la cuenta tuviera $750
RISK_PER_TRADE=0.001       # (informativo; el mapa por simbolo vive en el codigo)
AGG_RISK_CAP=0.006
DAILY_LOSS_KILL=0.05
