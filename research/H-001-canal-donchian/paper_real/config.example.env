# Config del PAPER-REAL (precios REALES de mainnet, SIN dinero).
# SIN API KEYS a proposito: solo lee datos publicos -> no puede colocar ordenes.
# Doble seguro: DRY_RUN=true (no envia ordenes) + sin keys (no puede).
EXCHANGE_ID=binance
EXCHANGE_TESTNET=false     # false = MAINNET (precios reales); NO tocar
DRY_RUN=true               # true = paper (fills simulados); NO tocar
API_KEY=                   # vacio a proposito
API_SECRET=                # vacio a proposito
PAPER_EQUITY=10000         # capital paper (el riesgo es %, la escala da igual)
EQUITY_CAP=0               # sin tope
